<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_background_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:background="@drawable/widget_background_rounded">

    <!-- Hora -->
    <TextClock
        android:id="@+id/tv_widget_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-light"
        android:format24Hour="HH:mm"
        android:textColor="@color/text_primary"
        android:textSize="88sp" />

    <!-- Cidade -->
    <TextView
        android:id="@+id/tv_widget_city"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:textColor="@color/text_tertiary"
        android:textSize="18sp" />

    <!-- Temperatura e clima -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_widget_weather_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tv_widget_temperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="22sp" />
    </LinearLayout>

    <!-- Dia da semana -->
    <TextView
        android:id="@+id/tv_widget_weekday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="24sp" />

    <!-- Data completa -->
    <TextView
        android:id="@+id/tv_widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:textColor="@color/text_subtle"
        android:textSize="22sp" />

</LinearLayout>
